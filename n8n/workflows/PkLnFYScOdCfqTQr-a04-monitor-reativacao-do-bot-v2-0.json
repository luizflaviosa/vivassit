    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT chatwoot_url, chatwoot_account_id, telegram_chat_id, tenant_id, clinic_name\nFROM tenants\nWHERE chatwoot_inbox_id = '{{ $json.inbox_id }}'\n  AND status = 'active'\nLIMIT 1",
        "options": {}
      },
