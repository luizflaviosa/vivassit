        {
            "id": "62640725-e5ac-4e22-b7df-ca56bb2038aa",
            "name": "Get Available Slots",
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.5,
            "position": [
                224,
                0
            ],
            "parameters": {
                "operation": "executeQuery",
                "query": "=SELECT * FROM public.fn_get_available_slots(\n  '{{ $('When Called').item.json.tenant_id }}',\n  NULLIF(NULLIF('{{ $('When Called').item.json.doctor_name }}', ''), 'null'),\n  NULLIF(NULLIF('{{ $('When Called').item.json.doctor_id }}', ''), 'null')::uuid,\n  '{{ $('When Called').item.json.from_date }}'::date,\n  '{{ $('When Called').item.json.to_date }}'::date,\n  {{ $('When Called').item.json.limit || 2 }},\n  NULLIF(NULLIF('{{ $('When Called').item.json.doctor_code ?? '' }}', ''), 'null')::int\n)",
                "options": {}
            },
            "credentials": {
                "postgres": {
                    "id": "2MWvHIrEZHdAbAz1",
                    "name": "Postgres account"
                }
            }
        },
        {
            "id": "3b6047e7-e555-490a-9782-55f7335f7b02",
            "name": "Format Response",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                448,
                0
            ],
            "parameters": {
                "mode": "runOnceForAllItems",
                "language": "javaScript",
                "jsCode": "const items = $input.all();\nconst slots = items.map(i => i.json).filter(s => s.slot_start);\n\nif (slots.length === 0) {\n  return [{ json: {\n    available: false,\n    count: 0,\n    message: 'Nenhum slot dispon\u00edvel no per\u00edodo pedido. Sugira ao paciente expandir o range.',\n    slots: []\n  }}];\n}\n\nconst formatBR = (iso) => {\n  const d = new Date(iso);\n  return d.toLocaleString('pt-BR', { \n    timeZone: 'America/Sao_Paulo',\n    weekday: 'short', day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit'\n  });\n};\n\nconst formatted = slots.map(s => ({\n  slot_iso: s.slot_start,\n  end_iso: s.slot_end,\n  doctor_code: s.doctor_code,\n  doctor_name: s.doctor_name,\n  day_label: s.day_label,\n  display: formatBR(s.slot_start),\n  working_window: s.working_window\n}));\n\nreturn [{ json: {\n  available: true,\n  count: slots.length,\n  doctor_code: slots[0].doctor_code,\n  doctor_name: slots[0].doctor_name,\n  message: 'Tenho ' + slots.length + ' hor\u00e1rios dispon\u00edveis (mais pr\u00f3ximos primeiro). Ofere\u00e7a ao paciente e use slot_iso EXATO + doctor_code pra chamar safe_create_event.',\n  slots: formatted\n}}];\n"
            }
        }
    ],
