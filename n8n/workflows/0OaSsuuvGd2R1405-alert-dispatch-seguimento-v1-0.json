{
  "id": "0OaSsuuvGd2R1405",
  "name": "Alert Dispatch · Seguimento · v1.0",
  "active": true,
  "versionId": "eb311ed4-3ff9-4386-ab29-d2ac9dd0f4ed",
  "nodes": [
    {
      "id": "alt-sched-01",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [0, 0],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/5 * * * *"
            }
          ]
        }
      }
    },
    {
      "id": "alt-pg-query-01",
      "name": "Postgres — Query Pending Alerts",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [240, 0],
      "parameters": {
        "operation": "executeQuery",
        "query": "select\n  ae.id as alert_event_id,\n  ae.tenant_id,\n  ae.patient_id,\n  ae.severity,\n  ae.source,\n  ae.reason,\n  ae.created_at,\n  t.clinic_name,\n  t.admin_phone,\n  t.doctor_phone,\n  pat.name as patient_name,\n  pat.phone as patient_phone,\n  case when pat.birthdate is not null\n       then extract(year from age(pat.birthdate))::int\n       else null end as patient_age\nfrom public.alert_events ae\njoin public.tenants t on t.tenant_id = ae.tenant_id\njoin public.patients pat on pat.id = ae.patient_id\nwhere ae.notified_doctor_whatsapp = false\n  and ae.severity in ('warning','critical')\n  and ae.created_at > now() - interval '24 hours'\norder by ae.severity = 'critical' desc, ae.created_at asc\nlimit 50;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "2MWvHIrEZHdAbAz1",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "alt-switch-01",
      "name": "Switch — Severity",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [480, 0],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "crit-rule",
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "critical",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "critical"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "warn-rule",
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "warning",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "warning"
            }
          ]
        },
        "options": {
          "fallbackOutput": "none"
        }
      }
    },
    {
      "id": "alt-if-doctor-01",
      "name": "IF — Doctor Phone Present",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [720, -160],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "has-doctor-phone",
              "leftValue": "={{ $json.doctor_phone }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "alt-evo-crit-doctor-01",
      "name": "Evolution — Critical to Doctor",
      "type": "n8n-nodes-evolution-api.evolutionApi",
      "typeVersion": 1,
      "position": [960, -280],
      "parameters": {
