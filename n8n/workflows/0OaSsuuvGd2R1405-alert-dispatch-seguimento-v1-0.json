        "operation": "send-text",
        "instanceName": "singulare-admin",
        "remoteJid": "={{ $json.doctor_phone.replace(/\\D/g, '') }}@s.whatsapp.net",
        "messageText": "=ALERTA CRITICO - {{ $json.clinic_name }}\n\nPaciente: {{ $json.patient_name }}{{ $json.patient_age ? ' (' + $json.patient_age + ' anos)' : '' }}\nMotivo: {{ $json.reason }}\nOrigem: {{ $json.source }}\nQuando: {{ $json.created_at }}\n\nAcesse o briefing no painel ou retorne contato com o paciente."
      },
      "onError": "continueRegularOutput",
