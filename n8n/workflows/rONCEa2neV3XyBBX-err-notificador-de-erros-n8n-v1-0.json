      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        320,
        0
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.n8n_historico_mensagens (session_id, tenant_id, message)\nVALUES (\n  'system_workflow_errors',\n  'admin-system',\n  jsonb_build_object(\n    'type', 'tool',\n    'name', 'workflow_error',\n    'content', jsonb_build_object(\n      'workflow_id',    $1::text,\n      'workflow_name',  $2::text,\n      'execution_id',   $3::text,\n      'execution_url',  $4::text,\n      'last_node',      $5::text,\n      'error_message',  $6::text,\n      'timestamp',      $7::text\n    ),\n    'tool_call_id', $8::text\n  )\n);",
        "options": {
          "queryReplacement": "={{ ($json.workflow || {}).id || '' }},{{ ($json.workflow || {}).name || '' }},{{ ($json.execution || {}).id || '' }},{{ ($json.execution || {}).url || '' }},{{ ($json.execution || {}).lastNodeExecuted || '' }},{{ ((($json.execution || {}).error || {}).message || '').replace(/,/g, ';').replace(/'/g, '\"') }},{{ $now.toISO() }},err_{{ $now.toMillis() }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "2MWvHIrEZHdAbAz1",
          "name": "Postgres account"
        }
      },
      "onError": "continueRegularOutput"
    }
  ],
