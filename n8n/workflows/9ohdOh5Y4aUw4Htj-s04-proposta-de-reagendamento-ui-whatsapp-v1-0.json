        {
            "id": "code-format-s04",
            "name": "Formatar dados",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                688,
                304
            ],
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "// Formata datas em BRT legivel e monta payload para os proximos nodes.\nconst tenantRow = $input.item.json;\nconst payload = $('Webhook Proposta').first().json.body;\n\nfunction utcToBRT(isoString) {\n  if (!isoString) return '';\n  try {\n    const dt = new Date(isoString);\n    if (isNaN(dt.getTime())) return isoString;\n    const brtTime = new Date(dt.getTime() - 3 * 60 * 60 * 1000);\n    const dias = ['domingo', 'segunda-feira', 'terca-feira', 'quarta-feira', 'quinta-feira', 'sexta-feira', 'sabado'];\n    const dayName = dias[brtTime.getUTCDay()];\n    const dd = String(brtTime.getUTCDate()).padStart(2, '0');\n    const mm = String(brtTime.getUTCMonth() + 1).padStart(2, '0');\n    const hh = String(brtTime.getUTCHours()).padStart(2, '0');\n    const min = String(brtTime.getUTCMinutes()).padStart(2, '0');\n    const timeStr = min === '00' ? hh + 'h' : hh + 'h' + min;\n    return dayName + ', ' + dd + '/' + mm + ' as ' + timeStr;\n  } catch(e) { return isoString; }\n}\n\nconst urlBase = (tenantRow.chatwoot_url || '').replace(/\\/$/, '');\nconst doctorName = tenantRow.doctor_name || 'a profissional';\nconst patientName = payload.patient_name || 'tudo bem';\nconst firstName = (payload.patient_name || '').split(' ')[0] || '';\n\nconst oldSlotBrt = utcToBRT(payload.old_slot_start);\nconst newSlotBrt = utcToBRT(payload.new_slot_start);\n\nconst mensagemPaciente =\n  'Ola' + (firstName ? ', ' + firstName : '') + '! Aqui e da ' + (tenantRow.clinic_name || 'clinica') + '.\\n\\n' +\n  doctorName + ' precisou reorganizar a agenda e gostariamos de sugerir um novo horario pra sua consulta.\\n\\n' +\n  '*Consulta atual:* ' + oldSlotBrt + '\\n' +\n  '*Nova sugestao:* ' + newSlotBrt + '\\n\\n' +\n  'Esse novo horario funciona pra voce? Se sim, e so responder *\"sim\"* ou *\"confirmo\"*.\\n' +\n  'Se preferir outro dia ou horario, me avisa e a gente acha o melhor jeito juntos.';\n\nconst notaInterna =\n  'Proposta de reagendamento enviada ao paciente via UI.\\n\\n' +\n  'Proposto por: ' + (payload.proposed_by_name || '(nao identificado)') + '\\n' +\n  'Antes: ' + oldSlotBrt + '\\n' +\n  'Depois: ' + newSlotBrt + '\\n\\n' +\n  'Aguardando resposta do paciente (deadline ' + utcToBRT(payload.confirmation_expires_at) + ').';\n\nconst telegramMsg =\n  '*Proposta de reagendamento enviada*\\n\\n' +\n  'Clinica: ' + (tenantRow.clinic_name || tenantRow.tenant_id) + '\\n' +\n  'Paciente: ' + (payload.patient_name || payload.patient_phone) + '\\n' +\n  'Antes: ' + oldSlotBrt + '\\n' +\n  'Depois: ' + newSlotBrt + '\\n' +\n  'Por: ' + (payload.proposed_by_name || '(nao identificado)') + '\\n' +\n  'Deadline: ' + utcToBRT(payload.confirmation_expires_at);\n\nreturn {\n  json: {\n    booking_id: payload.booking_id,\n    tenant_id: tenantRow.tenant_id,\n    clinic_name: tenantRow.clinic_name,\n    doctor_name: doctorName,\n    patient_phone: payload.patient_phone,\n    patient_name: payload.patient_name,\n    conversation_id: payload.conversation_id,\n    chatwoot_url: urlBase,\n    chatwoot_account_id: tenantRow.chatwoot_account_id,\n    telegram_chat_id: tenantRow.telegram_chat_id,\n    old_slot_brt: oldSlotBrt,\n    new_slot_brt: newSlotBrt,\n    mensagem_paciente: mensagemPaciente,\n    nota_interna: notaInterna,\n    telegram_msg: telegramMsg,\n  }\n};"
            }
        },
