            "parameters": {
                "operation": "executeQuery",
                "query": "=SELECT \n  t.tenant_id,\n  t.clinic_name,\n  t.chatwoot_url,\n  t.chatwoot_account_id,\n  t.telegram_chat_id,\n  d.doctor_name\nFROM public.tenants t\nLEFT JOIN public.tenant_doctors d\n  ON d.id = '{{ $json.body.doctor_id }}'::uuid\nWHERE t.tenant_id = '{{ $json.body.tenant_id }}'\n  AND t.status = 'active'\nLIMIT 1",
