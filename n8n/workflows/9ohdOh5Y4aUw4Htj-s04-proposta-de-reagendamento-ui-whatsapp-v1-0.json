te via UI.\\n\\n' +\n  'Proposto por: ' + (payload.proposed_by_name || '(nao identificado)') + '\\n' +\n  'Antes: ' + oldSlotBrt + '\\n' +\n  'Depois: ' + newSlotBrt + '\\n\\n' +\n  'Aguardando resposta do paciente (deadline ' + utcToBRT(payload.confirmation_expires_at) + ').';\n\nconst telegramMsg =\n  '*Proposta de reagendamento enviada*\\n\\n' +\n  'Clinica: ' + (tenantRow.clinic_name || tenantRow.tenant_id) + '\\n' +\n  'Paciente: ' + (payload.patient_name || payload.patient_phone) + '\\n' +\n  'Antes: ' + oldSlotBrt + '\\n' +\n  'Depois: ' + newSlotBrt + '\\n' +\n  'Por: ' + (payload.proposed_by_name || '(nao identificado)') + '\\n' +\n  'Deadline: ' + utcToBRT(payload.confirmation_expires_at);\n\nreturn {\n  json: {\n    booking_id: payload.booking_id,\n    tenant_id: tenantRow.tenant_id,\n    clinic_name: tenantRow.clinic_name,\n    doctor_name: doctorName,\n    patient_phone: payload.patient_phone,\n    patient_name: payload.patient_name,\n    conversation_id: payload.conversation_id,\n    chatwoot_url: urlBase,\n    chatwoot_account_id: tenantRow.chatwoot_account_id,\n    telegram_chat_id: tenantRow.telegram_chat_id,\n    old_slot_brt: oldSlotBrt,\n    new_slot_brt: newSlotBrt,\n    mensagem_paciente: mensagemPaciente,\n    nota_interna: notaInterna,\n    telegram_msg: telegramMsg,\n  }\n};"
