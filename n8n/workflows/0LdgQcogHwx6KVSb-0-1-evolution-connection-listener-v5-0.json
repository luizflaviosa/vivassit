        "text": "=✅ WhatsApp CONECTADO\\n\\n🏥 {{ $('Lookup Tenant').item.json.clinic_name }}\\n👨‍⚕️ {{ $('Lookup Tenant').item.json.doctor_name }}\\n🆔 {{ $('Lookup Tenant').item.json.tenant_id }}\\n📱 Clínica: {{ $('Lookup Tenant').item.json.phone }}\\n👤 Admin: {{ $('Lookup Tenant').item.json.admin_phone || '(não informado)' }}\\n🩺 Médico: {{ $('Lookup Tenant').item.json.doctor_phone || '(igual ao admin)' }}\\n\\n⚡ IA atendendo agora.\\n💬 Welcome msg enviada via singulare-admin.",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
