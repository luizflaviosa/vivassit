    },
    {
      "id": "6707dcc2-161b-4745-8b6a-c582738279f5",
      "name": "Parse Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        192
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const inp=$input.first().json||{};const body=inp.body||{};const data=body.data||{};return[{event:body.event||'',instance:body.instance||'',state:data.state||'',is_connected:body.event==='connection.update'&&data.state==='open',raw:body}];"
      }
    },
    {
      "id": "cdf6c351-500c-4f52-8fb3-2185e32ef9e9",
      "name": "Connected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        448,
        192
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.is_connected }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "70c4927b-2110-48a7-b9cb-69f4d5b35af7",
      "name": "Lookup Tenant",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        672,
        96
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT tenant_id, doctor_name, clinic_name, phone, admin_phone, doctor_phone, welcomed_at FROM public.tenants WHERE evolution_instance_name = '{{ $json.instance }}' OR tenant_id = '{{ $json.instance }}' LIMIT 1",
        "options": {}
      },
      "alwaysOutputData": true,
      "onError": "continueRegularOutput",
      "credentials": {
        "postgres": {
          "id": "2MWvHIrEZHdAbAz1",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "eef1b403-eaae-459b-9633-f09626512eab",
      "name": "Not Welcomed Yet?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        896,
        96
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "has_tenant",
              "leftValue": "={{ $json.tenant_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "no_welcome",
              "leftValue": "={{ $json.welcomed_at }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "empty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "a8342985-ada1-4a9e-add8-d2043ea4917d",
      "name": "Mark Connected + Welcomed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1120,
        0
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE public.tenants SET evolution_status='connected', welcomed_at=NOW(), updated_at=NOW() WHERE tenant_id='{{ $json.tenant_id }}'",
        "options": {}
      },
      "onError": "continueRegularOutput",
      "credentials": {
        "postgres": {
          "id": "2MWvHIrEZHdAbAz1",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "build-recipients-1",
      "name": "Build Recipients",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -96
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const t=$('Lookup Tenant').item.json;\nconst norm=(p)=>(p||'').toString().replace(/\\D/g,'');\nconst clinic=norm(t.phone);\nconst admin=norm(t.admin_phone);\nconst doctor=norm(t.doctor_phone);\nconst seen=new Set();\nconst out=[];\nif(clinic){ seen.add(clinic); out.push({phone:clinic,label:'clínica'}); }\nif(admin && !seen.has(admin)){ seen.add(admin); out.push({phone:admin,label:'admin'}); }\nif(doctor && !seen.has(doctor)){ seen.add(doctor); out.push({phone:doctor,label:'médico'}); }\nreturn out.map(r=>({json:{phone:r.phone,label:r.label,doctor_name:t.doctor_name||'',clinic_name:t.clinic_name||'',tenant_id:t.tenant_id||''}}));"
      }
    },
    {
      "id": "62da131c-ea19-467a-9ae4-da3be1632e66",
      "name": "Send Welcome WhatsApp",
      "type": "n8n-nodes-evolution-api.evolutionApi",
      "typeVersion": 1,
      "position": [
        1568,
        -96
      ],
      "parameters": {
        "resource": "messages-api",
        "operation": "send-text",
        "instanceName": "singulare-admin",
        "remoteJid": "={{ $json.phone }}@s.whatsapp.net",
        "messageText": "=Dr(a). {{ $json.doctor_name }}, sua clínica está no ar 🎉\n\nA *{{ $json.clinic_name }}* já tem secretária IA própria. Ela atende seus pacientes no WhatsApp da clínica 24/7 e cuida de agenda, cobrança e lembretes — você fica com o que importa.\n\n*Pra começar:*\n\n→ Painel da clínica: https://app.singulare.org/painel\n→ Guia rápido (12 dúvidas comuns): https://singulare.org/bem-vindo\n\nQualquer coisa, responda este número — somos a Singulare e te ajudamos direto.\n\nBoas consultas. 🩺"
      },
      "onError": "continueRegularOutput",
      "credentials": {
        "evolutionApi": {
          "id": "yFAQwH6wPqroKla0",
          "name": "Evolution account"
        }
      }
    },
    {
      "id": "19b39223-9058-4aa2-85a9-b75badafe852",
      "name": "Notify Admin",
