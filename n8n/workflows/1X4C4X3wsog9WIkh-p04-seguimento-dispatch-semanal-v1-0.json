      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "=update public.patient_protocols\n   set last_dispatched_at = now(),\n       updated_at = now()\n where id = '{{ $json.patient_protocol_id }}';",
        "options": {}
      },
      "credentials": {
