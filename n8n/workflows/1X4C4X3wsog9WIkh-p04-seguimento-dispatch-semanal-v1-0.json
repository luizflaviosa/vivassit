  "nodes": [
    {
      "id": "p04-sched-01",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        0,
        0
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 12 * * 1"
            }
          ]
        }
      }
    },
    {
      "id": "p04-pg-query-01",
      "name": "Postgres — Query Due Patients",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        240,
        0
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "with due as (\n  select pp.id as patient_protocol_id,\n         pp.patient_id,\n         pp.tenant_id,\n         pp.protocol_id,\n         pp.started_at,\n         pp.last_dispatched_at,\n         floor(extract(epoch from (now() - pp.started_at)) / 86400 / 7)::int as week_index\n  from public.patient_protocols pp\n  where pp.status = 'active'\n    and (pp.last_dispatched_at is null\n         or pp.last_dispatched_at < now() - interval '6 days 12 hours')\n),\nquestion_counts as (\n  select protocol_id, count(*) as num_questions\n  from public.protocol_questions\n  where is_active = true\n  group by protocol_id\n),\nchosen as (\n  select d.*,\n         qc.num_questions,\n         (d.week_index % greatest(qc.num_questions, 1)) + 1 as chosen_ordering\n  from due d\n  join question_counts qc on qc.protocol_id = d.protocol_id\n)\nselect\n  c.patient_protocol_id,\n  c.patient_id,\n  c.tenant_id,\n  pq.id as protocol_question_id,\n  pq.ordering,\n  pq.kind,\n  pq.prompt_pt,\n  t.clinic_name,\n  pat.phone as patient_phone,\n  pat.first_name as patient_first_name,\n  pat.health_collection_token\nfrom chosen c\njoin public.protocol_questions pq\n  on pq.protocol_id = c.protocol_id\n  and pq.ordering = c.chosen_ordering\n  and pq.is_active = true\njoin public.tenants t on t.tenant_id = c.tenant_id\njoin public.patients pat on pat.id = c.patient_id\nwhere pat.phone is not null\norder by c.patient_protocol_id;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "2MWvHIrEZHdAbAz1",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "p04-split-01",
      "name": "SplitInBatches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        480,
        0
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "p04-evo-send-01",
      "name": "Evolution — Send WhatsApp",
      "type": "n8n-nodes-evolution-api.evolutionApi",
      "typeVersion": 1,
      "position": [
        720,
        0
      ],
      "parameters": {
        "resource": "messages-api",
        "operation": "send-text",
        "instanceName": "singulare-admin",
        "remoteJid": "={{ $json.patient_phone.replace(/\\D/g, '') }}@s.whatsapp.net",
        "messageText": "=Oi, {{ $json.patient_first_name }}! Aqui e a {{ $json.clinic_name }}. Hora do seu check-in semanal.\n\n{{ $json.prompt_pt }}\n\nPode responder por aqui mesmo ou pelo link:\nhttps://singulare.org/saude/{{ $json.health_collection_token }}"
      },
      "onError": "continueRegularOutput",
      "credentials": {
        "evolutionApi": {
          "id": "yFAQwH6wPqroKla0",
          "name": "Evolution account"
        }
      }
    },
    {
      "id": "p04-pg-update-01",
      "name": "Postgres — Update last_dispatched_at",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        960,
