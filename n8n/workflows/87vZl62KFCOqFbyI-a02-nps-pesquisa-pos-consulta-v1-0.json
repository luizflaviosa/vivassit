    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  d.id AS doctor_id,\n  d.doctor_name,\n  d.calendar_id,\n  t.tenant_id,\n  t.evolution_instance_name,\n  t.chatwoot_url,\n  t.chatwoot_account_id,\n  t.chatwoot_inbox_id\nFROM public.tenant_doctors d\nJOIN public.tenants t ON t.tenant_id = d.tenant_id\nWHERE t.status = 'active'\n  AND t.evolution_status = 'connected'\n  AND t.evolution_instance_name IS NOT NULL\n  AND t.chatwoot_url IS NOT NULL\n  AND t.chatwoot_account_id IS NOT NULL\n  AND t.chatwoot_inbox_id IS NOT NULL\n  AND d.status = 'active'\n  AND d.calendar_id IS NOT NULL",
        "options": {}
      },
