        "query": "INSERT INTO public.patient_feedback\n  (tenant_id, patient_name, patient_phone, doctor_name,\n   appointment_date, status, sent_at, booking_id)\nVALUES\n  ('{{ $('List Bookings Completed Today').item.json.tenant_id }}',\n   '{{ $('List Bookings Completed Today').item.json.patient_name }}',\n   '{{ $('List Bookings Completed Today').item.json.patient_phone }}',\n   '{{ $('List Bookings Completed Today').item.json.doctor_name }}',\n   '{{ $('List Bookings Completed Today').item.json.appointment_date }}',\n   'pending', NOW(),\n   '{{ $('List Bookings Completed Today').item.json.booking_id }}'::uuid)\nRETURNING id;",
        "options": {}
      },
