    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst phone = body.patient_phone || '';\nreturn [{ json: {\n  tenant_id: body.tenant_id || 'singulare',\n  chatwoot_url: body.chatwoot_url || 'https://chatwoot.singulare.org',\n  chatwoot_account_id: body.chatwoot_account_id || 1,\n  chatwoot_inbox_id: body.chatwoot_inbox_id || 3,\n  doctor_name: body.doctor_name || 'Dra. Paula Franzon',\n  appointment_date: new Date().toISOString(),\n  patient_phone: phone,\n  patient_name: body.patient_name || phone,\n  first_name: (body.patient_name || 'Paciente').split(' ')[0],\n  _test_mode: true\n}}];"
      },
      "id": "inject-test-data-001",
      "name": "Inject Test Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        -280
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  b.id::text                AS booking_id,\n  b.tenant_id,\n  b.patient_name,\n  b.patient_phone,\n  b.slot_start              AS appointment_date,\n  d.doctor_name,\n  t.evolution_instance_name,\n  t.chatwoot_url,\n  t.chatwoot_account_id,\n  t.chatwoot_inbox_id\nFROM public.doctor_bookings b\nJOIN public.tenant_doctors d ON d.id = b.doctor_id\nJOIN public.tenants t        ON t.tenant_id = b.tenant_id\nWHERE b.doctor_id = '{{ $json.doctor_id }}'\n  AND b.status = 'completed'\n  AND (b.slot_start AT TIME ZONE 'America/Sao_Paulo')::date\n      = ((now() AT TIME ZONE 'America/Sao_Paulo')::date)\n  AND NOT EXISTS (\n    SELECT 1 FROM public.patient_feedback f\n    WHERE f.booking_id = b.id\n  );",
        "options": {}
      },
