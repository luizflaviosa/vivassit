        "method": "POST",
        "url": "={{ $('List Bookings Completed Today').item.json.chatwoot_url.replace(/\\/$/, '') }}/api/v1/accounts/{{ $('List Bookings Completed Today').item.json.chatwoot_account_id }}/conversations",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "chatwootApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contact_id\": {{ ($('Search Contact').item.json.payload && $('Search Contact').item.json.payload[0] && $('Search Contact').item.json.payload[0].id) || 0 }},\n  \"inbox_id\": \"{{ $('List Bookings Completed Today').item.json.chatwoot_inbox_id }}\",\n  \"status\": \"open\",\n  \"message\": {\n    \"content\": \"Olá {{ $('List Bookings Completed Today').item.json.patient_name.split(' ')[0] }}! 👋\\n\\nComo foi sua consulta hoje com {{ $('List Bookings Completed Today').item.json.doctor_name }}?\\nDe 0 a 10, qual nota você daria?\\n\\n_Caso não tenha comparecido à consulta, é só ignorar esta mensagem._\"\n  }\n}",
