          "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst phone = body.patient_phone || '';\nreturn [{ json: {\n  tenant_id: body.tenant_id || 'singulare',\n  chatwoot_url: body.chatwoot_url || 'https://chatwoot.singulare.org',\n  chatwoot_account_id: body.chatwoot_account_id || 1,\n  chatwoot_inbox_id: body.chatwoot_inbox_id || 3,\n  doctor_name: body.doctor_name || 'Dra. Paula Franzon',\n  appointment_date: new Date().toISOString(),\n  patient_phone: phone,\n  patient_name: body.patient_name || phone,\n  first_name: (body.patient_name || 'Paciente').split(' ')[0],\n  _test_mode: true\n}}];"
